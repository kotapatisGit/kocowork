{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kocowork-website",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "cd project && npm ci && npm run build"
  },
  "assets": {
    "directory": "project/dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
